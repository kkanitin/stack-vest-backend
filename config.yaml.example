server:
  port: "8080"

log:
  level: "info"       # debug | info | warn | error
  format: "json"      # json | text

db:
  postgres:
    dsn: "postgres://user:password@localhost:5432/stackvest?sslmode=disable"
  migrate:
    enabled: true   # set to false to skip auto-migration on startup

auth:
  google:
    client_id: "YOUR_GOOGLE_CLIENT_ID"
    client_secret: "YOUR_GOOGLE_CLIENT_SECRET"
    redirect_url: "http://localhost:8080/api/v1/auth/google/callback"
  #jwt:
    secret: "YOUR_JWT_SECRET_CHANGE_ME"

third_party_api:
  fmp:
    api_key: "YOUR_FMP_API_KEY"
  groq:
    api_key: "YOUR_GROQ_API_KEY"

redis:
  addr: "localhost:6379"   # host:port of the Redis used for the dividend cache
  password: ""
  db: 0

cors:
  allow_origins:
    - "http://localhost:5173"   # add your frontend origin(s) here

portfolio:
  max_per_user: 10                  # max portfolios a single user can own
  max_positions_per_portfolio: 20   # max positions within one portfolio